# Template for environment variables
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
FIELD_INSIGHTS_BASE_URL=https://YOUR_CLOUD_RUN_URL/api
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_CLOUD_RUN_URL/api/auth/google-callback

# Cloud backend model and Earth Engine linkage
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
EARTH_ENGINE_MODE=live
EARTH_ENGINE_PROJECT_ID=YOUR_GCP_PROJECT_ID
EARTH_ENGINE_SERVICE_ACCOUNT_JSON={}

# Firebase / Firestore (optional for persisting field insights)
FIREBASE_PROJECT_ID=YOUR_GCP_PROJECT_ID
FIREBASE_SERVICE_ACCOUNT_JSON={}
FIREBASE_COLLECTION=fieldInsights
FIREBASE_WEB_API_KEY=YOUR_FIREBASE_WEB_API_KEY

# Vertex AI Search (Knowledge Base)
VERTEX_SEARCH_ENABLED=true
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_COLLECTION=default_collection
VERTEX_SEARCH_DATA_STORE=
VERTEX_SEARCH_SERVING_CONFIG=default_search